# iag-dms-depot-node — environment configuration

# --- identity ---
SERVICE_NAME=dms-depot-node
DEPOT_ID=depot-local
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=text
PORT=4020

# --- persistence ---
# Omit DATABASE_URL and set STORE_MODE=memory for a non-durable local run.
DATABASE_URL=postgres://svc_dms_depot_node:iag_dms_depot_node_dev@localhost:5432/iag_platform?sslmode=disable
# STORE_MODE=memory
AUTO_MIGRATE=true

# --- inbound auth (tokens this node verifies) ---
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.dms-depot-node

# --- outbound service auth (for upstream sync + permission registration) ---
SERVICE_CLIENT_ID=iag-dms-depot-node
SERVICE_CLIENT_SECRET=
AUTH_TOKEN_URL=http://localhost:3001/oauth/token

# --- upstream sync to central DMS (via gateway) ---
# Leave DMS_UPSTREAM_URL empty to run in pure-buffer mode (no sync).
DMS_UPSTREAM_URL=http://localhost:8080/api/v1/dms
DMS_UPSTREAM_AUDIENCE=iag.dms
DMS_INGEST_PATH=/v1/depot/documents
SYNC_ENABLED=true
SYNC_INTERVAL=15s
SYNC_BATCH_SIZE=25
# MAX_SYNC_ATTEMPTS=0   # 0 = retry forever with backoff

# --- heartbeat + events ---
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL=60s
EVENT_BUS_ENABLED=false
KAFKA_BROKERS=

# --- CORS (production must set an explicit allowlist, never *) ---
# ALLOWED_ORIGINS=https://depot.example.com
